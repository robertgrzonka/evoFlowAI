# Server Configuration
NODE_ENV=development
PORT=3001

# Database
MONGODB_URI=mongodb://localhost:27017/evoflowai

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
ENABLE_LOCAL_PASSWORD_RESET=true
PASSWORD_RESET_TTL_MINUTES=30
APP_URL=http://localhost:3000

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here
# Default: gpt-4o-mini. GPT-5 family (Chat Completions): e.g. gpt-5, gpt-5-2025-08-07, gpt-5.1, gpt-5.1-2025-11-13, gpt-5 mini/nano — see https://platform.openai.com/docs/models
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3
# Optional, only applied when OPENAI_MODEL is a GPT-5 family id (or OPENAI_USE_GPT5_CHAT_PARAMS=true):
# OPENAI_REASONING_EFFORT=low
# Allowed: none, minimal, low, medium, high, xhigh (subset may apply per model)
# OPENAI_VERBOSITY=medium
# Allowed: low, medium, high, auto
# OPENAI_USE_GPT5_CHAT_PARAMS=true

# Security
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
