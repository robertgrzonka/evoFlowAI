# Server Configuration
NODE_ENV=development
PORT=3001
# Listen address (use 0.0.0.0 in Docker / Railway so healthchecks can reach the process)
# HOST=0.0.0.0

# Database
# Local MongoDB (default for dev):
MONGODB_URI=mongodb://localhost:27017/evoflowai
#
# MongoDB Atlas — use the database name in the path (same as local), e.g. /evoflowai:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/evoflowai?appName=evoFlowAI
# If the password contains special characters (!, @, #, etc.), URL-encode them (e.g. ! → %21).
# In Atlas: Network Access → allow your IP (or 0.0.0.0/0 only for quick local experiments).

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
ENABLE_LOCAL_PASSWORD_RESET=true
PASSWORD_RESET_TTL_MINUTES=30
APP_URL=http://localhost:3000

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here
# Default: gpt-4o-mini (matches a typical Railway setup). GPT-5 family (Chat Completions): e.g. gpt-5,
# gpt-5-2025-08-07, gpt-5.1, gpt-5-mini — see https://platform.openai.com/docs/models
OPENAI_MODEL=gpt-4o-mini
#
# Local GPT-5 without changing this file: process env wins over .env, so from repo root run:
#   npm run dev:gpt5
# (backend uses OPENAI_MODEL=gpt-5; web unchanged). Override for one shell, e.g. mini:
#   cd backend && cross-env OPENAI_MODEL=gpt-5-mini npm run dev
OPENAI_TEMPERATURE=0.3
# Optional, only applied when OPENAI_MODEL is a GPT-5 family id (or OPENAI_USE_GPT5_CHAT_PARAMS=true).
# Defaults if unset: reasoning_effort=minimal, verbosity=low (faster UX; raise if quality drops).
# OPENAI_REASONING_EFFORT=none
# Allowed: none, minimal, low, medium, high, xhigh (subset may apply per model)
# OPENAI_VERBOSITY=medium
# Allowed: low, medium, high, auto
# OPENAI_USE_GPT5_CHAT_PARAMS=true
# GPT-5: minimum max_completion_tokens (each call uses at least this). Reasoning can consume the budget before visible text. Default 16384; override up to 128000 if needed.
# OPENAI_GPT5_MIN_COMPLETION_TOKENS=32768
# Meal vision/text JSON: GPT-5 completion budget (reasoning + visible JSON). Too low → empty reply. Default 12288; max 65536.
# OPENAI_FOOD_LOG_GPT5_COMPLETION_BUDGET=16384
# Evo Coach Pro (plan + details + drawer JSON). Default 65536; max 128000. Raise if GPT-5 returns finish_reason=length on coach-pro.
# OPENAI_COACH_PRO_GPT5_COMPLETION_BUDGET=98304

# Security
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
